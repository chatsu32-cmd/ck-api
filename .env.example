PORT=3000
JWT_SECRET=change-this-to-a-long-random-string-in-production

# 通知設定: none / email / line / both
NOTIFY_METHOD=none

# メール設定（NOTIFY_METHOD=email または both の場合）
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM=CKシステム <your@gmail.com>
MAIL_TO=ck-staff@example.com

# LINE Notify設定（NOTIFY_METHOD=line または both の場合）
LINE_TOKEN=your-line-notify-token
